<header>
  <h1>
    <%= page_title %>
  </h1>

  <div>

    <% if is_signed_in? %>

      <form action="<%= session_destroy_path %>" method="post" id="sign_out_form">
        <input type="hidden" name="_method" value="delete">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      </form>

      <button type="submit" form="sign_out_form">Sign out</button>

    <% end %>

  </div>

</header>

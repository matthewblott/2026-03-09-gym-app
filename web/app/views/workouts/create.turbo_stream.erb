<turbo-stream action="append" target="exercises">
  <template>
    <%= render "exercises/exercise", exercise: @exercise %>
  </template>
</turbo-stream>

<turbo-stream action="replace" target="new_exercise">
  <template>
    <%= render "exercises/new_form", workout: @workout, exercise: Exercise.new %>
  </template>
</turbo-stream>

<turbo-stream action="remove" target="no-exercises"></turbo-stream>

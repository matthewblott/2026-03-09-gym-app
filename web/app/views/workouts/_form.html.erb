<form action="<%= workout.new_record? ? workouts_path(Current.user) : workout_path(Current.user, workout) %>"
  method="post" accept-charset="UTF-8">
  <% unless workout.new_record? %>
    <input type="hidden" name="_method" value="patch">
  <% end %>
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

  <% if workout.errors.any? %>
    <ul role="list">
      <% workout.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  <% end %>

  <fieldset>
    <legend>Workout details</legend>

    <label for="workout_created_at">Started at</label>
    <input type="datetime-local" name="workout[created_at]" id="workout_created_at" required
           value="<%= workout.created_at&.strftime("%Y-%m-%dT%H:%M") %>">
  </fieldset>

  <button type="submit"><%= workout.new_record? ? "Start workout" : "Save changes" %></button>
</form>

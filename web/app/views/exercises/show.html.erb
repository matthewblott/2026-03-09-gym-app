<% content_for :title, @exercise.name %>

<section>
  <header>
    <h1><%= @exercise.name %></h1>
    <nav>
      <a href="<%= workout_path(Current.user, @exercise.workout) %>">Back to workout</a>
    </nav>
  </header>

  <turbo-frame id="<%= dom_id(@exercise, "sets") %>">
    <% if @exercise.exercise_sets.any? %>
      <table>
        <thead>
          <tr>
            <th scope="col">Set</th>
            <th scope="col">Reps</th>
            <th scope="col">Weight</th>
            <th scope="col"><span aria-label="Actions">–</span></th>
          </tr>
        </thead>
        <tbody>
          <% @exercise.exercise_sets.each_with_index do |set, i| %>
            <%= render "sets/set", set: set, index: i + 1 %>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p id="no-sets">No sets yet.</p>
    <% end %>
  </turbo-frame>

  <turbo-frame id="<%= dom_id(@exercise, "new_set") %>">
    <%= render "sets/new_form",
          exercise: @exercise,
          set: ExerciseSet.new %>
  </turbo-frame>
</section>

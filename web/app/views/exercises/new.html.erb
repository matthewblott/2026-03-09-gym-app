<% content_for :title, "New Exercise" %>

<% content_for :header_content do %>
  <form action="<%= create_exercise_path(Current.user, workout_id: @workout_id) %>" method="post" id="exercise-form">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    <input type="hidden" name="exercise[workout_id]" value="<%= @workout_id %>">
  </form>

  <div role="group">
    <a href="<%= exercises_path(Current.user, workout_id: @workout_id) %>" role="button">Exercises</a>
    <button form="exercise-form">Save</button>
  </div>
<% end %>

<fieldset>
  <div class="mt-xxl">
    <input
      type="text"
      form="exercise-form"
      id="name"
      name="exercise[name]"
      placeholder="Exercise name"
      aria-label="Exercise name"
      list="exercise-names"
      required
    >
    <datalist id="exercise-names">
      <option value="Running">
      <option value="Cycling">
      <option value="Swimming">
      <option value="Bench Press">
      <option value="Squats">
    </datalist>
  </div>
  <div role="radiogroup">
    <label>
      <input
        form="exercise-form"
        type="radio"
        name="exercise[exercise_type]"
        value="cardio"
        required
      >
      Cardio
    </label>
    <label>
      <input
        form="exercise-form"
        type="radio"
        name="exercise[exercise_type]"
        value="weights"
      >
      Weights
    </label>
  </div>
</fieldset>

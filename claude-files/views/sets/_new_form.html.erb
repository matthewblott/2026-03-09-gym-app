<%= form_with model: [exercise.session, exercise, set],
               url: session_exercise_sets_path(exercise.session, exercise),
               data: { turbo_frame: dom_id(exercise, "sets") } do |f| %>
  <% if set.errors.any? %>
    <ul role="list">
      <% set.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  <% end %>

  <fieldset>
    <legend>Log a set</legend>

    <label for="<%= dom_id(exercise, "set_reps") %>">Reps</label>
    <input type="number"
           id="<%= dom_id(exercise, "set_reps") %>"
           name="exercise_set[reps]"
           min="1"
           required>

    <label for="<%= dom_id(exercise, "set_weight") %>">Weight (kg)</label>
    <input type="number"
           id="<%= dom_id(exercise, "set_weight") %>"
           name="exercise_set[weight]"
           min="0"
           step="0.5"
           required>

    <%= f.submit "Log set" %>
  </fieldset>
<% end %>
